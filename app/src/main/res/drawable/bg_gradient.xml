<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Warna dasar biru -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3A76A6"/> <!-- Base blue -->
        </shape>
    </item>

    <!-- Radial glow di tengah -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="500dp"
                android:centerX="50%"
                android:centerY="60%"
                android:startColor="#80A6C7E1"
                android:endColor="#003A76A6"
                android:useLevel="false" />
        </shape>
    </item>

</layer-list>
