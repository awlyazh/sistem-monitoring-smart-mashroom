<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#D8E8F9">

    <!-- ScrollView untuk konten utama -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_header_blue">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pengembunan\nJamur Tiram"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:textAlignment="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Taruna Jaya"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:textAlignment="center" />

                <TextView
                    android:id="@+id/textSuhu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="25.1°"
                    android:textColor="@android:color/white"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textAlignment="center" />

                <TextView
                    android:id="@+id/textFeels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Feels like: 25.1°\nHumidity: 90.0%"
                    android:textColor="@android:color/white"
                    android:textAlignment="center" />
            </LinearLayout>

            <!-- Auto Switch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical|start"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1A3F3D"
                    android:layout_marginRight="8dp" />

                <Switch
                    android:id="@+id/switchAuto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@android:color/darker_gray"
                    android:trackTint="@android:color/darker_gray"
                    android:minWidth="80dp"
                    android:padding="16dp" />
            </LinearLayout>

            <!-- Status Text -->
            <TextView
                android:id="@+id/textStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pengembunan manual jamur tiram sedang berhenti"
                android:textColor="#1A3F3D"
                android:textAlignment="center"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <!-- Button Manual ON/OFF -->
            <Button
                android:id="@+id/btnManual"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:text="OFF"
                android:textSize="16sp"
                android:layout_gravity="center"
                android:background="@drawable/bg_button_off"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <!-- Card Section (Status Sensor/Suhu & Humidity) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="16dp">

                <!-- Card untuk Humidity -->
                <LinearLayout
                    android:id="@+id/cardHumidity"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:background="@color/card_temp_stable"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/textStatusHumidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: Off"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textHumidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧 Humidity\n85.0 %"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Card untuk Temperature -->
                <LinearLayout
                    android:id="@+id/cardTemp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:background="@color/card_humid_stable"
                    android:padding="12dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/textStatusTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: Off"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textTempControl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌡 Temp. Control\n25.1 °C"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#4677B2"
        app:labelVisibilityMode="unlabeled"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:menu="@menu/bottom_nav_menu" />
</LinearLayout>
