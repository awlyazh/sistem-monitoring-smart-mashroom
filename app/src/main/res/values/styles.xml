<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema aplikasi utama -->
    <style name="Theme.SmartMushroom" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Sesuaikan sesuai kebutuhan -->
        <item name="colorPrimary">#4677B2</item>
        <item name="colorPrimaryVariant">#2C5A91</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FF9800</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor" tools:targetApi="l">#4677B2</item>
    </style>

    <!-- Style untuk menghilangkan oval transparan (aktif indicator) di BottomNavigationView -->
    <style name="NoIndicator">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

</resources>
